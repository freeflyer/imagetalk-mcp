{
  "name": "@imagetalk/mcp",
  "version": "0.1.3",
  "description": "Stdio MCP server that wraps the ImageTalk backend REST API for use with Claude Desktop and other MCP clients.",
  "type": "module",
  "bin": {
    "imagetalk-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "claude",
    "claude-desktop",
    "image-search",
    "imagetalk",
    "stdio"
  ],
  "author": "Andrii Kvitka <andrii.kvitka@ukr.net>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/freeflyer/imagetalk-mcp#readme",
  "bugs": {
    "url": "https://github.com/freeflyer/imagetalk-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeflyer/imagetalk-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
